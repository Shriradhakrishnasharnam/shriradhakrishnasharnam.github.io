---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="section-title">
  {subtitle && <span class="subtitle">{subtitle}</span>}
  <h2>{title}</h2>
</div>

<style>
.section-title{
  text-align:center;
  margin-bottom:4rem;
}

.subtitle{
  display:inline-block;
  color:var(--primary);
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:.12em;
  margin-bottom:.75rem;
  font-size:.9rem;
}

.section-title h2{
  margin:0;
  font-size:clamp(2rem,4vw,3rem);
}
</style>
